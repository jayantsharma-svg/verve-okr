{
  "name": "@okr-tool/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc || true",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:migrate": "node --import tsx/esm src/db/migrate.ts",
    "db:seed": "node --import tsx/esm src/db/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@google-cloud/storage": "^5.18.3",
    "@google-cloud/tasks": "^5.5.2",
    "@okr-tool/core": "*",
    "@slack/bolt": "^3.22.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "eas-cli": "0.52.0",
    "eslint-config-next": "16.2.4",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^140.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "next": "16.2.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.12.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
