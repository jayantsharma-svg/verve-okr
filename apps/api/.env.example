# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/okr_tool

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_WORKSPACE_DOMAIN=yourcompany.com

# ─── Google APIs (service account for Sheets export + Directory sync) ─────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=okr-tool@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=base64-encoded-service-account-json
GOOGLE_SHEETS_EXPORT_ID=your-google-sheet-id

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# ─── Anthropic / Claude AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Google Cloud Storage ────────────────────────────────────────────────────
GCS_BUCKET_NAME=okr-tool-files
GCS_PROJECT_ID=your-gcp-project-id

# ─── Google Cloud Tasks ───────────────────────────────────────────────────────
GCP_TASKS_QUEUE_NAME=okr-tool-jobs
GCP_TASKS_LOCATION=us-central1
GCP_PROJECT_ID=your-gcp-project-id
INTERNAL_TASKS_SECRET=change-me-tasks-secret

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
